{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc",
    "backend": "nodemon src/server.ts",
    "setup:chatbot": "cd phone_recs_bot && py -3.12 -m venv .venv && .venv\\Scripts\\python.exe -m pip install -r requirements.txt",
    "chatbot": "cd phone_recs_bot && .venv\\Scripts\\python.exe -m uvicorn app.main:app --reload",
    "setup:chatbot:mac": "cd phone_recs_bot && python3.12 -m venv .venv && .venv/bin/python -m pip install -r requirements.txt",
    "setup:chatbot:linux": "python3 -m venv ../.venv && ../.venv/bin/pip install -r phone_recs_bot/requirements.txt",
    "chatbot:mac": "cd phone_recs_bot && .venv/bin/python -m uvicorn app.main:app --reload",
    "chatbot:linux": "cd phone_recs_bot && ../../.venv/bin/python -m uvicorn app.main:app --reload",
    "dev": "concurrently \"npm run backend\" \"npm run chatbot\"",
    "dev:mac": "concurrently \"npm run backend\" \"npm run chatbot:mac\"",
    "dev:linux": "concurrently \"npm run backend\" \"npm run chatbot:linux\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@sendgrid/mail": "^8.1.5",
    "bad-words": "^4.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "mongo-sanitize": "^1.1.0",
    "mongoose": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.7",
    "@types/mongo-sanitize": "^1.0.3",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^24.10.2",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
